# ============================================
# PostgreSQL
# ============================================
# 数据库连接地址（开发期用 localhost，Neon 线上给完整 URL）
DATABASE_URL=postgres://youhui:youhui123@localhost:5432/youhui

# ============================================
# Redis
# ============================================
REDIS_URL=redis://default:youhui123@localhost:16379/0

# ============================================
# JWT
# ============================================
# 生产环境请换一个足够长的随机字符串
JWT_SECRET=dev-secret-change-in-production

# ============================================
# 应用配置
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# 存储（开发期用 local-fs，线上切 s3）
# ============================================
STORAGE_DRIVER=local-fs
# local-fs
LOCAL_FS_ROOT=./uploads
LOCAL_FS_PUBLIC_BASE_URL=http://localhost:3000/uploads
# s3（STORAGE_DRIVER=s3 时必填）
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=youhui
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
# ============================================
# PostgreSQL
# ============================================
# 数据库连接地址（开发期用 localhost，Neon 线上给完整 URL）
DATABASE_URL=postgres://youhui:youhui123@localhost:5432/youhui

# ============================================
# Redis
# ============================================
REDIS_URL=redis://default:youhui123@localhost:6379/0

# ============================================
# JWT
# ============================================
# 生产环境请换一个足够长的随机字符串
JWT_SECRET=dev-secret-change-in-production

# ============================================
# 应用配置
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# 存储（开发期用 local-fs，线上切 s3）
# ============================================
STORAGE_DRIVER=local-fs
# S3 兼容存储（MinIO / 七牛 / R2 等）
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=auto
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=youhui
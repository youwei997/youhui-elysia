    "check": "biome check --write src/",
    "typecheck": "bun run --check src/index.ts",
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3"
  },
  "module": "src/index.js"
}
